{
  "title": "Exchange API Sandbox",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "type": "timeseries",
      "title": "API Calls",
      "targets": [{"expr": "sum(rate(exchange_api_calls_total[1m])) by (route)"}],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "Orders",
      "targets": [{"expr": "sum(rate(exchange_orders_total[1m])) by (status)"}],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "Latency",
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(exchange_latency_seconds_bucket[5m])) by (le, operation))"}],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
    },
    {
      "type": "timeseries",
      "title": "Reconnects",
      "targets": [{"expr": "sum(rate(exchange_reconnects_total[5m])) by (exchange, symbol)"}],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
    }
  ]
}

